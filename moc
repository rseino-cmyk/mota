.link-blue:hover{text-decoration:underline;}

/* ===== 論点タグ ===== */
.issue-tag{display:inline-block;background:#fff3cd;border:1px solid #ffc107;color:#856404;font-size:10px;font-weight:700;padding:1px 6px;border-radius:2px;margin-left:6px;vertical-align:middle;}
.design-note{font-size:11px;color:#999;background:#f5f5f5;border-radius:4px;padding:12px 14px;text-align:left;line-height:1.7;margin-top:16px;}
.design-note strong{color:#555;display:block;margin-bottom:4px;}

/* ===== ステップ説明バー ===== */
.step-desc-bar{background:#1a1a1a;color:white;padding:12px 28px;display:flex;align-items:center;gap:16px;}
.step-desc-num{background:#c0392b;color:white;font-size:11px;font-weight:900;padding:3px 10px;border-radius:3px;white-space:nowrap;}
.step-desc-title{font-size:14px;font-weight:700;}
.step-desc-actor{font-size:11px;color:#aaa;margin-left:auto;}

/* ===== 引渡し確認 ===== */
.handover-box{background:white;border:1px solid #e0e0e0;border-radius:4px;padding:20px 24px;margin-bottom:16px;}
.handover-title{font-size:15px;font-weight:700;margin-bottom:12px;}
.handover-list{list-style:none;}
.handover-list li{padding:6px 0;font-size:13px;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:8px;}
.handover-list li::before{content:'□';font-size:16px;color:#aaa;}
.handover-list li.checked::before{content:'✅';font-size:14px;}

/* ===== 受取連絡（キャンセル・減額） ===== */
.action-card{background:white;border:1px solid #e0e0e0;border-radius:4px;padding:20px 24px;margin-bottom:12px;}
.action-card-title{font-size:14px;font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.action-card-body{font-size:13px;color:#555;line-height:1.8;}

/* ===== 送金完了 ===== */
.transfer-complete{text-align:center;padding:48px 20px;}
.tc-icon{font-size:60px;margin-bottom:16px;}
.tc-title{font-size:24px;font-weight:700;margin-bottom:8px;}
.tc-amount{font-size:36px;font-weight:900;color:#1D6B35;margin-bottom:8px;}
.tc-body{font-size:13px;color:#666;line-height:1.9;}

/* ===== 請求書プレビュー ===== */
.invoice-box{background:white;border:1px solid #ccc;border-radius:4px;padding:32px;max-width:640px;margin:0 auto;}
.invoice-title{font-size:22px;font-weight:700;text-align:center;margin-bottom:4px;}
.invoice-sub{font-size:12px;color:#666;text-align:center;margin-bottom:24px;}
.invoice-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;font-size:12px;}
.invoice-table{width:100%;border-collapse:collapse;margin-bottom:16px;}
.invoice-table th{background:#1a1a1a;color:white;padding:8px 12px;font-size:12px;text-align:left;}
.invoice-table td{padding:10px 12px;font-size:13px;border-bottom:1px solid #e0e0e0;}
.invoice-total{text-align:right;font-size:16px;font-weight:700;color:#1a1a1a;}
.pay-method{background:#f0f4ff;border:1px solid #c5d3f0;border-radius:4px;padding:14px 16px;margin-top:16px;font-size:12px;}

/* ===== 入金確認 ===== */
.amount-confirm-box{background:#e8f5e9;border:2px solid #1D6B35;border-radius:6px;padding:20px 24px;text-align:center;margin-bottom:20px;}
.acb-label{font-size:12px;color:#1D6B35;font-weight:700;margin-bottom:4px;}
.acb-amount{font-size:32px;font-weight:900;color:#1D6B35;}
.acb-note{font-size:11px;color:#555;margin-top:4px;}

